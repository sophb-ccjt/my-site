{
    "cleanUrls": true,
    "outputDirectory": ".",
    "buildCommand": "cp /backend/apis /frontend/api",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/apis/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}