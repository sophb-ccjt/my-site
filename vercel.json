{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "services",
  "experimentalServices": [
    {
      "name": "web-frontend",
      "src": "frontend",
      "routes": [
        {
          "src": "/frontend/(.*)",
          "dest": "/$1"
        }
      ]
    },
    {
      "name": "api-backend",
      "src": "backend",
      "routes": [
        {
          "src": "/backend/apise/(.*)",
          "dest": "/api/$1"
        }
      ]
    }
  ]
}
